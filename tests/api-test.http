###
# ============================================================
# AUTH
# ============================================================

### [1] Register normal user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "email": "zamil@test.com",
  "password": "password123",
  "password_confirmation": "password123"
}

### [2] Register admin (already seeded — just login)

### [3] Login as admin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@admin.com",
  "password": "admin123"
}

### [4] Login as normal user
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "user@test.com",
  "password": "password123"
}

### [5] Logout (requires token)
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{adminToken}}

###
# ============================================================
# PLANS — WITHOUT AUTH (expect 401)
# ============================================================

### [6] Get plans list — no auth → 401
GET {{baseUrl}}/plans

### [7] Create plan — no auth → 401
POST {{baseUrl}}/plans
Content-Type: application/json

{
  "code": "basic",
  "name": "Basic Plan"
}

### [8] Update plan — no auth → 401
PUT {{baseUrl}}/plans/1
Content-Type: application/json

{
  "name": "Basic Plan Updated",
  "trial_days": 7,
  "is_active": true
}

### [9] Delete plan — no auth → 401
DELETE {{baseUrl}}/plans/1

###
# ============================================================
# PLANS — WITH USER TOKEN (not admin, expect 403 for writes)
# ============================================================

### [10] Get plans list — user token → 200
GET {{baseUrl}}/plans
Authorization: Bearer {{userToken}}

### [11] Get plan details (user view) — user token → 200
GET {{baseUrl}}/plans/1/details
Authorization: Bearer {{userToken}}

### [12] Create plan — user token (not admin) → 403
POST {{baseUrl}}/plans
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "code": "basic",
  "name": "Basic Plan",
  "trial_days": 7,
  "is_active": true
}

### [13] Delete plan — user token → 403
DELETE {{baseUrl}}/plans/1
Authorization: Bearer {{userToken}}

###
# ============================================================
# PLANS — WITH ADMIN TOKEN (expect success)
# ============================================================

### [14] Create plan — admin → 201
POST {{baseUrl}}/plans
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "code": "basic",
  "name": "Basic Plan",
  "description": "Entry level plan",
  "trial_days": 7,
  "is_active": true
}

### [15] Create plan duplicate code — admin → 422
POST {{baseUrl}}/plans
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "code": "basic",
  "name": "Basic Plan Duplicate",
  "trial_days": 0,
  "is_active": true
}

### [16] Create second plan (for testing)
POST {{baseUrl}}/plans
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "code": "pro",
  "name": "Pro Plan",
  "trial_days": 14,
  "is_active": true
}

### [17] Get plan (admin view) — admin → 200
GET {{baseUrl}}/plans/1
Authorization: Bearer {{adminToken}}

### [18] Update plan (PUT) — admin → 200
PUT {{baseUrl}}/plans/1
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Basic Plan Updated",
  "description": "Updated description",
  "trial_days": 7,
  "is_active": true
}

### [19] Patch plan (PATCH) — admin → 200
PATCH {{baseUrl}}/plans/1
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "is_active": false
}

### [20] Public plans list — no auth → 200 (active only)
GET {{baseUrl}}/plans/public

### [21] Delete plan that has no relations — admin → 204
DELETE {{baseUrl}}/plans/2
Authorization: Bearer {{adminToken}}

###
# ============================================================
# PLAN PRICES — WITHOUT AUTH (expect 401)
# ============================================================

### [22] Get plan prices — no auth → 401
GET {{baseUrl}}/plan-prices

