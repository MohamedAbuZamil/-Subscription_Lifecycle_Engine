{
  "info": {
    "name": "Subscription Lifecycle Engine",
    "description": "End-to-end ordered collection. Run via Newman or Postman Runner top-to-bottom. Tokens and IDs are saved automatically via test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": ["pm.request.headers.add({key:'Accept',value:'application/json'});"]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl",        "value": "http://127.0.0.1:8000/api" },
    { "key": "adminToken",     "value": "" },
    { "key": "userToken",      "value": "" },
    { "key": "planId",         "value": "" },
    { "key": "usdPriceId",     "value": "" },
    { "key": "aedPriceId",     "value": "" },
    { "key": "subscriptionId", "value": "" },
    { "key": "transactionId",  "value": "" }
  ],
  "item": [
    {
      "name": "01 — Auth",
      "item": [
        {
          "name": "Login admin → adminToken saved",
          "event": [{"listen":"test","script":{"exec":["var j=pm.response.json(); if(j.token) pm.collectionVariables.set('adminToken',j.token);"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/auth/login","host":["{{baseUrl}}"],"path":["auth","login"]},
            "body": {"mode":"raw","raw":"{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"admin123\"\n}"}
          }
        },
        {
          "name": "Register user → userToken saved",
          "event": [{"listen":"test","script":{"exec":["try{var j=pm.response.json();if(j.token)pm.collectionVariables.set('userToken',j.token);}catch(e){}"]}},
          {"listen":"prerequest","script":{"exec":[""]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/auth/register","host":["{{baseUrl}}"],"path":["auth","register"]},
            "body": {"mode":"raw","raw":"{\n  \"name\": \"Ahmed Ali\",\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"}
          }
        },
        {
          "name": "Login user (fallback if already registered)",
          "event": [{"listen":"test","script":{"exec":["try{var j=pm.response.json();if(j.token)pm.collectionVariables.set('userToken',j.token);}catch(e){}"]}},
          {"listen":"prerequest","script":{"exec":["if(pm.collectionVariables.get('userToken'))pm.execution.skipRequest();"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw":"{{baseUrl}}/auth/login","host":["{{baseUrl}}"],"path":["auth","login"]},
            "body": {"mode":"raw","raw":"{\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\"\n}"}
          }
        }
      ]
    },
    {
      "name": "02 — Plans",
      "item": [
        {
          "name": "Create plan → planId saved",
          "event": [{"listen":"test","script":{"exec":["var j=pm.response.json(); if(j.data&&j.data.id){pm.collectionVariables.set('planId',j.data.id+'');}else{pm.sendRequest({url:pm.collectionVariables.get('baseUrl')+'/plans',method:'GET',header:[{key:'Authorization',value:'Bearer '+pm.collectionVariables.get('adminToken')},{key:'Accept',value:'application/json'}]},function(err,res){var d=res.json();if(d.data){var p=d.data.find(function(x){return x.code==='basic';});if(p)pm.collectionVariables.set('planId',p.id+'');}});}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plans","host":["{{baseUrl}}"],"path":["plans"]},
            "body": {"mode":"raw","raw":"{\n  \"code\": \"basic\",\n  \"name\": \"Basic Plan\",\n  \"description\": \"Entry-level plan with trial\",\n  \"trial_days\": 14,\n  \"is_active\": true\n}"}
          }
        },
        {
          "name": "List plans (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plans","host":["{{baseUrl}}"],"path":["plans"]}
          }
        },
        {
          "name": "Get plan by ID (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plans/{{planId}}","host":["{{baseUrl}}"],"path":["plans","{{planId}}"]}
          }
        },
        {
          "name": "Update plan PATCH (admin)",
          "request": {
            "method": "PATCH",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plans/{{planId}}","host":["{{baseUrl}}"],"path":["plans","{{planId}}"]},
            "body": {"mode":"raw","raw":"{\n  \"is_active\": true\n}"}
          }
        },
        {
          "name": "Replace plan PUT (admin)",
          "request": {
            "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plans/{{planId}}","host":["{{baseUrl}}"],"path":["plans","{{planId}}"]},
            "body": {"mode":"raw","raw":"{\n  \"code\": \"basic\",\n  \"name\": \"Basic Plan\",\n  \"description\": \"Entry-level plan with trial\",\n  \"trial_days\": 14,\n  \"is_active\": true\n}"}
          }
        }
      ]
    },
    {
      "name": "03 — Plan Prices",
      "item": [
        {
          "name": "Create USD monthly price → usdPriceId saved",
          "event": [{"listen":"test","script":{"exec":["var j=pm.response.json(); if(j.data&&j.data.id){pm.collectionVariables.set('usdPriceId',j.data.id+'');}else{pm.sendRequest({url:pm.collectionVariables.get('baseUrl')+'/plan-prices',method:'GET',header:[{key:'Authorization',value:'Bearer '+pm.collectionVariables.get('adminToken')},{key:'Accept',value:'application/json'}]},function(err,res){var d=res.json();if(d.data){var p=d.data.find(function(x){return x.currency==='USD'&&x.billing_cycle==='monthly';});if(p)pm.collectionVariables.set('usdPriceId',p.id+'');}});}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices","host":["{{baseUrl}}"],"path":["plan-prices"]},
            "body": {"mode":"raw","raw":"{\n  \"plan_id\": {{planId}},\n  \"billing_cycle\": \"monthly\",\n  \"currency\": \"USD\",\n  \"price\": 9.99,\n  \"grace_period_days\": 3,\n  \"is_active\": true\n}"}
          }
        },
        {
          "name": "Create AED monthly price → aedPriceId saved",
          "event": [{"listen":"test","script":{"exec":["var j=pm.response.json(); if(j.data&&j.data.id){pm.collectionVariables.set('aedPriceId',j.data.id+'');}else{pm.sendRequest({url:pm.collectionVariables.get('baseUrl')+'/plan-prices',method:'GET',header:[{key:'Authorization',value:'Bearer '+pm.collectionVariables.get('adminToken')},{key:'Accept',value:'application/json'}]},function(err,res){var d=res.json();if(d.data){var p=d.data.find(function(x){return x.currency==='AED'&&x.billing_cycle==='monthly';});if(p)pm.collectionVariables.set('aedPriceId',p.id+'');}});}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices","host":["{{baseUrl}}"],"path":["plan-prices"]},
            "body": {"mode":"raw","raw":"{\n  \"plan_id\": {{planId}},\n  \"billing_cycle\": \"monthly\",\n  \"currency\": \"AED\",\n  \"price\": 36.99,\n  \"grace_period_days\": 3,\n  \"is_active\": true\n}"}
          }
        },
        {
          "name": "Create EGP monthly price (admin)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices","host":["{{baseUrl}}"],"path":["plan-prices"]},
            "body": {"mode":"raw","raw":"{\n  \"plan_id\": {{planId}},\n  \"billing_cycle\": \"monthly\",\n  \"currency\": \"EGP\",\n  \"price\": 299.00,\n  \"grace_period_days\": 3,\n  \"is_active\": true\n}"}
          }
        },
        {
          "name": "Create USD yearly price (admin)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices","host":["{{baseUrl}}"],"path":["plan-prices"]},
            "body": {"mode":"raw","raw":"{\n  \"plan_id\": {{planId}},\n  \"billing_cycle\": \"yearly\",\n  \"currency\": \"USD\",\n  \"price\": 99.99,\n  \"grace_period_days\": 3,\n  \"is_active\": true\n}"}
          }
        },
        {
          "name": "List plan prices (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices","host":["{{baseUrl}}"],"path":["plan-prices"]}
          }
        },
        {
          "name": "Get price by ID (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices/{{usdPriceId}}","host":["{{baseUrl}}"],"path":["plan-prices","{{usdPriceId}}"]}
          }
        },
        {
          "name": "Update USD price PATCH (admin)",
          "request": {
            "method": "PATCH",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices/{{usdPriceId}}","host":["{{baseUrl}}"],"path":["plan-prices","{{usdPriceId}}"]},
            "body": {"mode":"raw","raw":"{\n  \"price\": 11.99\n}"}
          }
        }
      ]
    },
    {
      "name": "04 — Subscriptions",
      "item": [
        {
          "name": "Create subscription — user USD (trialing) → subscriptionId saved",
          "event": [{"listen":"test","script":{"exec":["var j=pm.response.json(); if(j.data&&j.data.id){pm.collectionVariables.set('subscriptionId',j.data.id+'');}else{pm.sendRequest({url:pm.collectionVariables.get('baseUrl')+'/subscriptions',method:'GET',header:[{key:'Authorization',value:'Bearer '+pm.collectionVariables.get('adminToken')},{key:'Accept',value:'application/json'}]},function(err,res){var d=res.json();if(d.data&&d.data.length>0){pm.collectionVariables.set('subscriptionId',d.data[0].id+'');}});}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions","host":["{{baseUrl}}"],"path":["subscriptions"]},
            "body": {"mode":"raw","raw":"{\n  \"plan_id\": {{planId}},\n  \"billing_cycle\": \"monthly\"\n}"}
          }
        },
        {
          "name": "List subscriptions (admin — all)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions","host":["{{baseUrl}}"],"path":["subscriptions"]}
          }
        },
        {
          "name": "List subscriptions (user — own only)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions","host":["{{baseUrl}}"],"path":["subscriptions"]}
          }
        },
        {
          "name": "Get subscription by ID (user)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions/{{subscriptionId}}","host":["{{baseUrl}}"],"path":["subscriptions","{{subscriptionId}}"]}
          }
        }
      ]
    },
    {
      "name": "05 — Transactions",
      "item": [
        {
          "name": "Create transaction → transactionId saved",
          "event": [{"listen":"test","script":{"exec":["var j=pm.response.json(); if(j.data&&j.data.id){pm.collectionVariables.set('transactionId',j.data.id+'');}else{pm.sendRequest({url:pm.collectionVariables.get('baseUrl')+'/subscription-transactions',method:'GET',header:[{key:'Authorization',value:'Bearer '+pm.collectionVariables.get('adminToken')},{key:'Accept',value:'application/json'}]},function(err,res){var d=res.json();if(d.data&&d.data.length>0){pm.collectionVariables.set('transactionId',d.data[0].id+'');}});}"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions","host":["{{baseUrl}}"],"path":["subscription-transactions"]},
            "body": {"mode":"raw","raw":"{\n  \"subscription_id\": {{subscriptionId}},\n  \"provider\": \"manual\"\n}"}
          }
        },
        {
          "name": "List transactions (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions","host":["{{baseUrl}}"],"path":["subscription-transactions"]}
          }
        },
        {
          "name": "List transactions (user — own only)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions","host":["{{baseUrl}}"],"path":["subscription-transactions"]}
          }
        },
        {
          "name": "Get transaction by ID (admin)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions/{{transactionId}}","host":["{{baseUrl}}"],"path":["subscription-transactions","{{transactionId}}"]}
          }
        },
        {
          "name": "Mark paid → subscription becomes active",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions/{{transactionId}}/mark-paid","host":["{{baseUrl}}"],"path":["subscription-transactions","{{transactionId}}","mark-paid"]}
          }
        },
        {
          "name": "Get subscription — verify active",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions/{{subscriptionId}}","host":["{{baseUrl}}"],"path":["subscriptions","{{subscriptionId}}"]}
          }
        },
        {
          "name": "Mark past due — starts grace period (admin)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions/{{subscriptionId}}/mark-past-due","host":["{{baseUrl}}"],"path":["subscriptions","{{subscriptionId}}","mark-past-due"]},
            "body": {"mode":"raw","raw":"{\n  \"grace_period_ends_at\": \"2026-04-10T00:00:00Z\"\n}"}
          }
        },
        {
          "name": "Get subscription — verify past_due",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions/{{subscriptionId}}","host":["{{baseUrl}}"],"path":["subscriptions","{{subscriptionId}}"]}
          }
        },
        {
          "name": "Create 2nd transaction for grace period",
          "event": [{"listen":"test","script":{"exec":["var j=pm.response.json(); if(j.data&&j.data.id) pm.collectionVariables.set('transactionId',j.data.id+'');"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions","host":["{{baseUrl}}"],"path":["subscription-transactions"]},
            "body": {"mode":"raw","raw":"{\n  \"subscription_id\": {{subscriptionId}},\n  \"provider\": \"manual\"\n}"}
          }
        },
        {
          "name": "Mark failed (records failure reason)",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions/{{transactionId}}/mark-failed","host":["{{baseUrl}}"],"path":["subscription-transactions","{{transactionId}}","mark-failed"]},
            "body": {"mode":"raw","raw":"{\n  \"failure_reason\": \"Insufficient funds\"\n}"}
          }
        },
        {
          "name": "Create 3rd transaction and mark paid (reactivate)",
          "event": [{"listen":"test","script":{"exec":["var j=pm.response.json(); if(j.data&&j.data.id) pm.collectionVariables.set('transactionId',j.data.id+'');"]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions","host":["{{baseUrl}}"],"path":["subscription-transactions"]},
            "body": {"mode":"raw","raw":"{\n  \"subscription_id\": {{subscriptionId}},\n  \"provider\": \"manual\"\n}"}
          }
        },
        {
          "name": "Mark paid (reactivate subscription)",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions/{{transactionId}}/mark-paid","host":["{{baseUrl}}"],"path":["subscription-transactions","{{transactionId}}","mark-paid"]}
          }
        },
        {
          "name": "Refund → adds amount to user balance",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscription-transactions/{{transactionId}}/refund","host":["{{baseUrl}}"],"path":["subscription-transactions","{{transactionId}}","refund"]}
          }
        }
      ]
    },
    {
      "name": "06 — Lifecycle (cancel / expire / renew)",
      "item": [
        {
          "name": "Cancel subscription (user — owner)",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions/{{subscriptionId}}/cancel","host":["{{baseUrl}}"],"path":["subscriptions","{{subscriptionId}}","cancel"]}
          }
        },
        {
          "name": "Expire subscription (admin)",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions/{{subscriptionId}}/expire","host":["{{baseUrl}}"],"path":["subscriptions","{{subscriptionId}}","expire"]}
          }
        },
        {
          "name": "Extend period PUT (admin)",
          "request": {
            "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions/{{subscriptionId}}","host":["{{baseUrl}}"],"path":["subscriptions","{{subscriptionId}}"]},
            "body": {"mode":"raw","raw":"{\n  \"current_period_ends_at\": \"2027-01-01 00:00:00\"\n}"}
          }
        },
        {
          "name": "Renew subscription (admin)",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/subscriptions/{{subscriptionId}}/renew","host":["{{baseUrl}}"],"path":["subscriptions","{{subscriptionId}}","renew"]}
          }
        }
      ]
    },
    {
      "name": "07 — Cleanup (delete prices then plan, logout last)",
      "item": [
        {
          "name": "Delete USD price (admin)",
          "request": {
            "method": "DELETE",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices/{{usdPriceId}}","host":["{{baseUrl}}"],"path":["plan-prices","{{usdPriceId}}"]}
          }
        },
        {
          "name": "Delete AED price (admin)",
          "request": {
            "method": "DELETE",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plan-prices/{{aedPriceId}}","host":["{{baseUrl}}"],"path":["plan-prices","{{aedPriceId}}"]}
          }
        },
        {
          "name": "Delete plan (admin)",
          "request": {
            "method": "DELETE",
            "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}],
            "url": {"raw":"{{baseUrl}}/plans/{{planId}}","host":["{{baseUrl}}"],"path":["plans","{{planId}}"]}
          }
        },
        {
          "name": "Logout (user)",
          "request": {
            "method": "POST",
            "header": [{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "url": {"raw":"{{baseUrl}}/auth/logout","host":["{{baseUrl}}"],"path":["auth","logout"]}
          }
        }
      ]
    }
  ]
}
