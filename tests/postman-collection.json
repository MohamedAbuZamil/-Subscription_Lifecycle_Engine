{
  "info": {
    "name": "Subscription Lifecycle Engine",
    "description": "Ordered end-to-end collection. Run requests TOP TO BOTTOM. Each request depends on the one before it. Step 1: run [01] and [02] first to get tokens, then proceed in order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://127.0.0.1:8000/api", "type": "string" },
    { "key": "adminToken",     "value": "",                           "type": "string" },
    { "key": "userToken",      "value": "",                           "type": "string" },
    { "key": "planId",         "value": "",                          "type": "string" },
    { "key": "usdPriceId",     "value": "",                          "type": "string" },
    { "key": "aedPriceId",     "value": "",                          "type": "string" },
    { "key": "subscriptionId", "value": "",                          "type": "string" },
    { "key": "transactionId",  "value": "",                          "type": "string" }
  ],
  "item": [
    {
      "name": "STEP 1 — Auth (run these first)",
      "item": [
        {
          "name": "[01] Login admin → saves adminToken automatically",
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "if (json.token) pm.collectionVariables.set('adminToken', json.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@admin.com\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "[02] Register user → saves userToken automatically",
          "event": [{ "listen": "test", "script": { "exec": [
            "const json = pm.response.json();",
            "if (json.token) pm.collectionVariables.set('userToken', json.token);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ahmed Ali\",\n  \"email\": \"ahmed@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] }
          }
        }
      ]
    },
    {
      "name": "Plans",
      "item": [
        {
          "name": "List plans (any auth)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/plans", "host": ["{{baseUrl}}"], "path": ["plans"] }
          }
        },
        {
          "name": "Get plan by ID (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plans/1", "host": ["{{baseUrl}}"], "path": ["plans","1"] }
          }
        },
        {
          "name": "Create plan (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plans", "host": ["{{baseUrl}}"], "path": ["plans"] },
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"basic\",\n  \"name\": \"Basic Plan\",\n  \"description\": \"Entry-level plan with trial\",\n  \"trial_days\": 14,\n  \"is_active\": true\n}" }
          }
        },
        {
          "name": "Update plan (admin — PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plans/1", "host": ["{{baseUrl}}"], "path": ["plans","1"] },
            "body": { "mode": "raw", "raw": "{\n  \"is_active\": true\n}" }
          }
        },
        {
          "name": "Replace plan (admin — PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plans/1", "host": ["{{baseUrl}}"], "path": ["plans","1"] },
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"basic\",\n  \"name\": \"Basic Plan Updated\",\n  \"description\": \"Updated description\",\n  \"trial_days\": 14,\n  \"is_active\": true\n}" }
          }
        },
        {
          "name": "Delete plan (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plans/1", "host": ["{{baseUrl}}"], "path": ["plans","1"] }
          }
        }
      ]
    },
    {
      "name": "Plan Prices",
      "item": [
        {
          "name": "List plan prices (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plan-prices", "host": ["{{baseUrl}}"], "path": ["plan-prices"] }
          }
        },
        {
          "name": "Get price by ID (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plan-prices/1", "host": ["{{baseUrl}}"], "path": ["plan-prices","1"] }
          }
        },
        {
          "name": "Create price — USD monthly (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plan-prices", "host": ["{{baseUrl}}"], "path": ["plan-prices"] },
            "body": { "mode": "raw", "raw": "{\n  \"plan_id\": 1,\n  \"billing_cycle\": \"monthly\",\n  \"currency\": \"USD\",\n  \"price\": 9.99,\n  \"grace_period_days\": 3,\n  \"is_active\": true\n}" }
          }
        },
        {
          "name": "Create price — AED monthly (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plan-prices", "host": ["{{baseUrl}}"], "path": ["plan-prices"] },
            "body": { "mode": "raw", "raw": "{\n  \"plan_id\": 1,\n  \"billing_cycle\": \"monthly\",\n  \"currency\": \"AED\",\n  \"price\": 36.99,\n  \"grace_period_days\": 3,\n  \"is_active\": true\n}" }
          }
        },
        {
          "name": "Create price — EGP monthly (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plan-prices", "host": ["{{baseUrl}}"], "path": ["plan-prices"] },
            "body": { "mode": "raw", "raw": "{\n  \"plan_id\": 1,\n  \"billing_cycle\": \"monthly\",\n  \"currency\": \"EGP\",\n  \"price\": 299.00,\n  \"grace_period_days\": 3,\n  \"is_active\": true\n}" }
          }
        },
        {
          "name": "Create price — USD yearly (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plan-prices", "host": ["{{baseUrl}}"], "path": ["plan-prices"] },
            "body": { "mode": "raw", "raw": "{\n  \"plan_id\": 1,\n  \"billing_cycle\": \"yearly\",\n  \"currency\": \"USD\",\n  \"price\": 99.99,\n  \"grace_period_days\": 3,\n  \"is_active\": true\n}" }
          }
        },
        {
          "name": "Update price (admin — PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plan-prices/1", "host": ["{{baseUrl}}"], "path": ["plan-prices","1"] },
            "body": { "mode": "raw", "raw": "{\n  \"price\": 11.99\n}" }
          }
        },
        {
          "name": "Delete price (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/plan-prices/2", "host": ["{{baseUrl}}"], "path": ["plan-prices","2"] }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Create subscription — user (auto detects currency from IP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions", "host": ["{{baseUrl}}"], "path": ["subscriptions"] },
            "body": { "mode": "raw", "raw": "{\n  \"plan_id\": 1,\n  \"billing_cycle\": \"monthly\"\n}" }
          }
        },
        {
          "name": "Create subscription — UAE user (AED pricing via X-Country header)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "X-Country", "value": "AE" }
            ],
            "url": { "raw": "{{baseUrl}}/subscriptions", "host": ["{{baseUrl}}"], "path": ["subscriptions"] },
            "body": { "mode": "raw", "raw": "{\n  \"plan_id\": 1,\n  \"billing_cycle\": \"monthly\"\n}" }
          }
        },
        {
          "name": "List subscriptions (admin — all users)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions", "host": ["{{baseUrl}}"], "path": ["subscriptions"] }
          }
        },
        {
          "name": "List subscriptions (user — own only, max 10)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions", "host": ["{{baseUrl}}"], "path": ["subscriptions"] }
          }
        },
        {
          "name": "Get subscription by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/1", "host": ["{{baseUrl}}"], "path": ["subscriptions","1"] }
          }
        },
        {
          "name": "Cancel subscription (owner only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/1/cancel", "host": ["{{baseUrl}}"], "path": ["subscriptions","1","cancel"] }
          }
        },
        {
          "name": "Activate subscription (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/1/activate", "host": ["{{baseUrl}}"], "path": ["subscriptions","1","activate"] }
          }
        },
        {
          "name": "Mark past due — starts grace period (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/1/mark-past-due", "host": ["{{baseUrl}}"], "path": ["subscriptions","1","mark-past-due"] }
          }
        },
        {
          "name": "Renew subscription (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/1/renew", "host": ["{{baseUrl}}"], "path": ["subscriptions","1","renew"] }
          }
        },
        {
          "name": "Expire subscription (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/1/expire", "host": ["{{baseUrl}}"], "path": ["subscriptions","1","expire"] }
          }
        },
        {
          "name": "Extend period (admin — PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscriptions/1", "host": ["{{baseUrl}}"], "path": ["subscriptions","1"] },
            "body": { "mode": "raw", "raw": "{\n  \"current_period_ends_at\": \"2027-01-01 00:00:00\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Subscription Transactions",
      "item": [
        {
          "name": "List transactions (admin — all)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscription-transactions", "host": ["{{baseUrl}}"], "path": ["subscription-transactions"] }
          }
        },
        {
          "name": "List transactions (user — own only, max 10)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscription-transactions", "host": ["{{baseUrl}}"], "path": ["subscription-transactions"] }
          }
        },
        {
          "name": "Get transaction by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscription-transactions/1", "host": ["{{baseUrl}}"], "path": ["subscription-transactions","1"] }
          }
        },
        {
          "name": "Create transaction (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscription-transactions", "host": ["{{baseUrl}}"], "path": ["subscription-transactions"] },
            "body": { "mode": "raw", "raw": "{\n  \"subscription_id\": 1,\n  \"provider\": \"manual\"\n}" }
          }
        },
        {
          "name": "Mark paid — auto-activates subscription (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscription-transactions/1/mark-paid", "host": ["{{baseUrl}}"], "path": ["subscription-transactions","1","mark-paid"] }
          }
        },
        {
          "name": "Mark failed — records failure reason (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscription-transactions/1/mark-failed", "host": ["{{baseUrl}}"], "path": ["subscription-transactions","1","mark-failed"] },
            "body": { "mode": "raw", "raw": "{\n  \"failure_reason\": \"Insufficient funds\"\n}" }
          }
        },
        {
          "name": "Refund — adds amount to user balance (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/subscription-transactions/1/refund", "host": ["{{baseUrl}}"], "path": ["subscription-transactions","1","refund"] }
          }
        }
      ]
    },
    {
      "name": "Cron Jobs (manual trigger)",
      "item": [
        {
          "name": "Trigger: expire trials",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/debug/expire-trials", "host": ["{{baseUrl}}"], "path": ["debug","expire-trials"] }
          }
        },
        {
          "name": "Trigger: cancel overdue after grace period",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/debug/expire-overdue", "host": ["{{baseUrl}}"], "path": ["debug","expire-overdue"] }
          }
        },
        {
          "name": "Trigger: auto-renew active subscriptions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/debug/auto-renew", "host": ["{{baseUrl}}"], "path": ["debug","auto-renew"] }
          }
        }
      ]
    }
  ]
}
